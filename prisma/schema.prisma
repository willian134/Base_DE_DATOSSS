datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Usuario {
  id     Int    @id @default(autoincrement())
  nombre String
  email  String @unique
  edad   Int
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}